<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>🌸 全能線上國語字典與學習系統</title>
  
  <!-- 📌 iPhone 桌面 App 圖示：使用高畫質 PNG Base64 圖案（100% 支援 iOS 加入主畫面） -->
  <link rel="apple-touch-icon" sizes="180x180" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512' width='512' height='512'><rect width='512' height='512' rx='120' fill='%23fef3c7'/><path d='M120,380 C120,290 190,260 256,260 C322,260 392,290 392,380 C392,420 360,430 256,430 C152,430 120,420 120,380 Z' fill='%23d97706'/><circle cx='256' cy='190' r='75' fill='%23fde68a'/><path d='M130,170 C130,110 382,110 382,170 L382,240 C320,220 256,250 256,250 C256,250 192,220 130,240 Z' fill='%23059669'/><path d='M256,120 L256,250' stroke='%23047857' stroke-width='8'/><circle cx='225' cy='185' r='8' fill='%231e293b'/><circle cx='287' cy='185' r='8' fill='%231e293b'/><path d='M240,205 Q256,218 272,205' stroke='%231e293b' stroke-width='6' fill='none' stroke-linecap='round'/></svg>">
  <link rel="icon" type="image/png" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512' width='512' height='512'><rect width='512' height='512' rx='120' fill='%23fef3c7'/><path d='M120,380 C120,290 190,260 256,260 C322,260 392,290 392,380 C392,420 360,430 256,430 C152,430 120,420 120,380 Z' fill='%23d97706'/><circle cx='256' cy='190' r='75' fill='%23fde68a'/><path d='M130,170 C130,110 382,110 382,170 L382,240 C320,220 256,250 256,250 C256,250 192,220 130,240 Z' fill='%23059669'/><path d='M256,120 L256,250' stroke='%23047857' stroke-width='8'/><circle cx='225' cy='185' r='8' fill='%231e293b'/><circle cx='287' cy='185' r='8' fill='%231e293b'/><path d='M240,205 Q256,218 272,205' stroke='%231e293b' stroke-width='6' fill='none' stroke-linecap='round'/></svg>">

  <style>
    @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;800;900&display=swap');
    
    * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Noto Sans TC', -apple-system, BlinkMacSystemFont, sans-serif; -webkit-tap-highlight-color: transparent; }
    
    body { background-color: #fff5f7; color: #4a3e3d; min-height: 100vh; display: flex; flex-direction: column; padding-bottom: 2rem; }
    
    /* 🌸 櫻花粉頂欄 */
    header { background: linear-gradient(135deg, #fce7f3 0%, #fbcfe8 100%); color: #831843; padding: 1.25rem 1rem; border-bottom: 2px dashed #f472b6; }
    .header-container { max-width: 1200px; margin: 0 auto; display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 0.75rem; }
    .badge { background-color: #f472b6; color: white; font-weight: 900; padding: 0.4rem 0.85rem; border-radius: 1rem; font-size: 1.1rem; box-shadow: 0 3px 8px rgba(244, 114, 182, 0.35); }
    .title-area h1 { font-size: 1.3rem; font-weight: 800; color: #831843; }
    .title-area p { color: #9d174d; font-size: 0.75rem; opacity: 0.85; margin-top: 0.1rem; }
    
    .btn-group { display: flex; gap: 0.4rem; flex-wrap: wrap; align-items: center; }
    .btn { padding: 0.45rem 0.85rem; font-size: 0.78rem; font-weight: 700; border-radius: 1rem; border: none; cursor: pointer; display: inline-flex; align-items: center; gap: 0.3rem; transition: all 0.15s ease; }
    .btn:active { transform: scale(0.95); }
    .btn-pink { background-color: #f472b6; color: white; box-shadow: 0 3px 8px rgba(244, 114, 182, 0.35); }
    .btn-rose { background-color: #fb7185; color: white; box-shadow: 0 3px 8px rgba(251, 113, 133, 0.35); }
    .btn-soft { background-color: #ffffff; color: #9d174d; border: 1.5px solid #fbcfe8; }

    /* 🌸 導覽頁籤 */
    nav { background-color: white; border-bottom: 2px solid #fbcfe8; position: sticky; top: 0; z-index: 30; box-shadow: 0 2px 10px rgba(251, 207, 232, 0.2); }
    .nav-container { max-width: 1200px; margin: 0 auto; display: flex; overflow-x: auto; padding: 0 0.5rem; scrollbar-width: none; }
    .nav-container::-webkit-scrollbar { display: none; }
    .nav-btn { padding: 0.85rem 1rem; font-size: 0.88rem; font-weight: 800; background: none; border: none; border-bottom: 4px solid transparent; color: #9d174d; opacity: 0.65; cursor: pointer; white-space: nowrap; }
    .nav-btn.active { opacity: 1; color: #db2777; border-bottom-color: #f472b6; }

    main { max-width: 1200px; margin: 0 auto; padding: 1.25rem 0.85rem; flex-grow: 1; width: 100%; }
    
    /* 🌸 萬能搜尋框控制列 */
    .filter-card { background-color: white; padding: 1.1rem; border-radius: 1.5rem; border: 2px solid #fbcfe8; margin-bottom: 1.25rem; box-shadow: 0 4px 12px rgba(251, 207, 232, 0.25); }
    .search-bar-container { display: flex; gap: 0.5rem; margin-top: 0.5rem; }
    .select-box, .input-box, .textarea-box { width: 100%; background-color: #fff5f7; border: 1.5px solid #fbcfe8; color: #831843; border-radius: 0.85rem; padding: 0.6rem 0.85rem; font-size: 0.88rem; outline: none; transition: border-color 0.2s; }
    .textarea-box { min-height: 110px; font-family: inherit; }
    .select-box:focus, .input-box:focus, .textarea-box:focus { border-color: #f472b6; background-color: white; }

    /* 🌸 字典查詢結果卡片 */
    .online-result-card { background-color: white; border-radius: 1.5rem; border: 2.5px solid #fbcfe8; padding: 1.5rem; margin-bottom: 1.25rem; box-shadow: 0 6px 16px rgba(251, 207, 232, 0.3); }
    .online-char-header { display: flex; align-items: center; gap: 1.2rem; margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 2px dashed #fce7f3; }
    .online-char-box { width: 5rem; height: 5rem; background-color: #fff1f2; border: 3px solid #fda4af; border-radius: 1.5rem; display: flex; align-items: center; justify-content: center; font-size: 2.8rem; font-weight: 900; color: #9f1239; box-shadow: inset 0 2px 6px rgba(253, 164, 175, 0.25); flex-shrink: 0; }

    /* 🌸 生字卡片網格 */
    .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(310px, 1fr)); gap: 1rem; }
    .char-card { background-color: white; border-radius: 1.5rem; border: 2px solid #fbcfe8; overflow: hidden; display: flex; flex-direction: column; justify-content: space-between; box-shadow: 0 4px 12px rgba(251, 207, 232, 0.2); }
    .card-body { padding: 1.15rem; }
    .card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; }
    .lesson-badge { font-size: 0.75rem; font-weight: 800; color: #9d174d; background-color: #fce7f3; padding: 0.25rem 0.65rem; border-radius: 0.75rem; }
    
    .audio-btn { width: 2.3rem; height: 2.3rem; border-radius: 50%; background-color: #fce7f3; color: #db2777; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; box-shadow: 0 2px 6px rgba(251, 207, 232, 0.6); }

    .meta-tag { display: inline-block; background-color: #fff1f2; color: #be123c; font-size: 0.72rem; font-weight: 700; padding: 0.15rem 0.5rem; border-radius: 0.5rem; margin-right: 0.3rem; margin-top: 0.2rem; }

    .term-item { padding: 0.65rem 0.85rem; border-radius: 0.85rem; background-color: #fff5f7; border: 1px solid #fbcfe8; margin-top: 0.5rem; }
    .term-title { font-weight: 800; font-size: 0.88rem; color: #831843; display: flex; justify-content: space-between; align-items: center; }
    .term-def { font-size: 0.78rem; color: #9d174d; margin-top: 0.25rem; line-height: 1.4; }
    .sentence-box { font-size: 0.75rem; color: #475569; background-color: #f8fafc; padding: 0.45rem 0.65rem; border-radius: 0.5rem; margin-top: 0.35rem; border-left: 3px solid #f472b6; }

    .card-footer { background-color: #fff1f2; padding: 0.65rem 1.15rem; border-top: 1px solid #ffe4e6; display: flex; justify-content: space-between; align-items: center; font-size: 0.75rem; flex-wrap: wrap; gap: 0.3rem; }

    /* 🌸 聽寫測驗特別區 */
    .quiz-card { background-color: white; border-radius: 1.25rem; border: 2px solid #fbcfe8; padding: 1rem; margin-bottom: 0.75rem; display: flex; justify-content: space-between; align-items: center; gap: 0.75rem; }
    .quiz-mask { background-color: #fbcfe8; color: transparent; user-select: none; border-radius: 0.5rem; padding: 0.1rem 0.5rem; cursor: pointer; transition: all 0.2s; }
    .quiz-mask.revealed { background-color: transparent; color: #831843; }

    .loading-spinner { display: inline-block; width: 1.2rem; height: 1.2rem; border: 3px solid #fbcfe8; border-top-color: #db2777; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    .hidden { display: none !important; }

    @media print {
      body { background-color: white !important; color: black !important; padding: 0 !important; }
      header, nav, .btn-group, .filter-card, .card-footer, .audio-btn, #searchSection { display: none !important; }
      main { max-width: 100% !important; padding: 0 !important; }
      .card-grid { display: block !important; }
      .char-card { page-break-inside: avoid; border: 1px solid #ccc !important; box-shadow: none !important; margin-bottom: 1.5rem !important; }
      .quiz-card { page-break-inside: avoid; border: 1px solid #999 !important; }
      .quiz-mask { background-color: transparent !important; color: black !important; border: 1px dashed #666; min-width: 80px; display: inline-block; }
    }
  </style>
</head>
<body>

  <header>
    <div class="header-container">
      <div style="display:flex; align-items:center; gap:0.6rem;">
        <div class="badge">🌸</div>
        <div class="title-area">
          <h1>全能國語線上字典與學習系統</h1>
          <p>任意字詞線上即時查字典、成語造句、國語發音與課文聽寫</p>
        </div>
      </div>
      <div class="btn-group">
        <button onclick="window.print()" class="btn btn-pink">🖨️ 列印學習單</button>
        <button onclick="exportData()" class="btn btn-soft">📤 備份</button>
        <button onclick="triggerImport()" class="btn btn-soft">📥 匯入</button>
        <button onclick="resetToDefaultData()" class="btn btn-rose">🔄 重置預設</button>
        <input type="file" id="importFile" style="display:none" accept=".json" onchange="handleFileImport(event)">
      </div>
    </div>
  </header>

  <nav>
    <div class="nav-container">
      <button onclick="switchTab('dict')" id="tab-dict" class="nav-btn active">🔍 線上萬能字典</button>
      <button onclick="switchTab('quiz')" id="tab-quiz" class="nav-btn">✍️ 聽寫測驗模式</button>
      <button onclick="switchTab('manage')" id="tab-manage" class="nav-btn">➕ 手動新增字詞</button>
      <button onclick="switchTab('batch')" id="tab-batch" class="nav-btn">⚡ 批次快速輸入</button>
    </div>
  </nav>

  <main>
    <!-- 搜尋與音速控制列 -->
    <div id="searchSection" class="filter-card">
      <label style="font-size: 0.85rem; font-weight: 800; color: #831843;">🔍 線上萬能字典搜尋（輸入任何單字、雙字詞或成語）：</label>
      <div class="search-bar-container">
        <input type="text" id="searchInput" onkeypress="if(event.key==='Enter') performUniversalSearch()" placeholder="例如輸入：蘋果、努力、海浪、急中生智..." class="input-box">
        <button onclick="performUniversalSearch()" class="btn btn-pink" style="padding: 0.6rem 1.25rem; font-size: 0.9rem; white-space: nowrap;">
          🔎 線上查詢
        </button>
      </div>

      <div style="display: flex; gap: 0.6rem; flex-wrap: wrap; align-items: center; margin-top: 0.85rem; padding-top: 0.75rem; border-top: 1px dashed #fbcfe8;">
        <div style="flex: 1; min-width: 140px;">
          <label style="font-size: 0.72rem; font-weight: 800; color: #9d174d;">📚 篩選國語課次：</label>
          <select id="lessonSelect" onchange="renderApp()" class="select-box" style="margin-top: 0.15rem;"></select>
        </div>
        <div style="flex: 1; min-width: 130px;">
          <label style="font-size: 0.72rem; font-weight: 800; color: #9d174d;">🔊 朗讀音速：</label>
          <select id="speechRateSelect" class="select-box" style="margin-top: 0.15rem;">
            <option value="0.5">🐢 慢速 (0.5x)</option>
            <option value="0.8" selected>🌸 正常 (0.8x)</option>
            <option value="1.2">🐇 快速 (1.2x)</option>
          </select>
        </div>
      </div>
    </div>

    <!-- 即時線上字典搜尋結果展示區 -->
    <div id="onlineSearchResultArea" class="hidden"></div>

    <!-- 1. 字典視圖 -->
    <section id="view-dict">
      <div id="dictContentList" class="card-grid"></div>
    </section>

    <!-- 2. 聽寫測驗視圖 -->
    <section id="view-quiz" class="hidden">
      <div style="background-color: white; padding: 1.25rem; border-radius: 1.5rem; border: 2px solid #fbcfe8;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.5rem;">
          <div>
            <h2 style="font-size: 1.15rem; font-weight: 800; color: #831843;">✍️ 圈詞聽寫測驗與自我練習</h2>
            <p style="font-size: 0.75rem; color: #9d174d; margin-top: 0.1rem;">點擊「🔊 播放題目」聽寫，點粉紅遮罩顯示答案；亦可點右上「🖨️ 列印」印出試卷！</p>
          </div>
          <button onclick="toggleAllQuizMasks()" class="btn btn-pink">👁️ 顯示/隱藏全部答案</button>
        </div>
        <div id="quizListContainer" style="display: flex; flex-direction: column;"></div>
      </div>
    </section>

    <!-- 3. 單筆新增視圖 -->
    <section id="view-manage" class="hidden">
      <div style="background-color: white; padding: 1.25rem; border-radius: 1.5rem; border: 2px solid #fbcfe8; max-width: 650px; margin: 0 auto;">
        <h2 style="font-size: 1.1rem; font-weight: 800; color: #831843; margin-bottom: 1rem;">📝 單筆新增 / 編輯生字與圈詞</h2>
        <form id="editForm" onsubmit="handleSaveForm(event)">
          <input type="hidden" id="editCharId">

          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.75rem; margin-bottom: 0.85rem;">
            <div>
              <label style="font-size: 0.72rem; font-weight: 800; color: #9d174d;">課次 *</label>
              <select id="editLesson" class="select-box" style="margin-top:0.2rem;" required></select>
            </div>
            <div>
              <label style="font-size: 0.72rem; font-weight: 800; color: #9d174d;">生字/詞語 *</label>
              <input type="text" id="editChar" placeholder="例如：墨 或 蘋果" class="input-box" style="margin-top:0.2rem;" required>
            </div>
            <div>
              <label style="font-size: 0.72rem; font-weight: 800; color: #9d174d;">注音 *</label>
              <input type="text" id="editZhuyin" placeholder="例如：ㄇㄛˋ" class="input-box" style="margin-top:0.2rem;" required>
            </div>
          </div>

          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.75rem; margin-bottom: 0.85rem;">
            <div>
              <label style="font-size: 0.72rem; font-weight: 800; color: #9d174d;">部首 *</label>
              <input type="text" id="editRadical" placeholder="例如：土部" class="input-box" style="margin-top:0.2rem;" required>
            </div>
            <div>
              <label style="font-size: 0.72rem; font-weight: 800; color: #9d174d;">總筆劃</label>
              <input type="text" id="editStrokes" placeholder="例如：15畫" class="input-box" style="margin-top:0.2rem;">
            </div>
          </div>

          <div style="margin-bottom: 0.85rem;">
            <label style="font-size: 0.72rem; font-weight: 800; color: #9d174d;">字義解釋</label>
            <input type="text" id="editCharMeaning" placeholder="例如：黑色書寫用的墨汁" class="input-box" style="margin-top:0.2rem;">
          </div>

          <div style="background-color: #fff5f7; padding: 0.85rem; border-radius: 1rem; margin-bottom: 0.75rem; border: 1.5px solid #fbcfe8;">
            <h4 style="font-size: 0.8rem; font-weight: 800; color: #831843; margin-bottom: 0.4rem;">相關圈詞 1</h4>
            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:0.5rem; margin-bottom:0.35rem;">
              <input type="text" id="editTerm1" placeholder="圈詞 (例如：墨汁)" class="input-box" required>
              <input type="text" id="editTerm1Zhuyin" placeholder="注音 (ㄇㄛˋ ㄓ)" class="input-box">
            </div>
            <input type="text" id="editTerm1Def" placeholder="圈詞解釋" class="input-box" style="margin-bottom:0.35rem;">
            <input type="text" id="editTerm1Sentence" placeholder="造句範例" class="input-box">
          </div>

          <div style="display: flex; justify-content: flex-end; gap: 0.5rem;">
            <button type="submit" class="btn btn-pink" style="padding: 0.6rem 1.4rem; font-size:0.85rem;">💾 儲存字詞資料</button>
          </div>
        </form>
      </div>
    </section>

    <!-- 4. 批次快速輸入視圖 -->
    <section id="view-batch" class="hidden">
      <div style="background-color: white; padding: 1.25rem; border-radius: 1.5rem; border: 2px solid #fbcfe8; max-width: 650px; margin: 0 auto;">
        <h2 style="font-size: 1.1rem; font-weight: 800; color: #831843; margin-bottom: 0.3rem;">⚡ 快速文字貼上批次匯入</h2>
        <p style="font-size: 0.72rem; color: #9d174d; margin-bottom: 0.85rem; line-height: 1.4;">
          一次可貼上多筆生字！格式為：<code>生字, 注音, 部首, 圈詞</code>（每行一筆）
        </p>

        <div style="margin-bottom: 0.85rem;">
          <label style="font-size: 0.72rem; font-weight: 800; color: #9d174d;">選擇匯入課次：</label>
          <select id="batchLessonSelect" class="select-box" style="margin-top:0.2rem;"></select>
        </div>

        <div style="margin-bottom: 0.85rem;">
          <label style="font-size: 0.72rem; font-weight: 800; color: #9d174d;">貼上文字資料：</label>
          <textarea id="batchInputText" class="textarea-box" placeholder="例如：
蘋果, ㄆㄧㄥˊ ㄍㄨㄛˇ, 艸部, 蘋果樹
努力, ㄋㄨˇ ㄌㄧˋ, 力部, 努力學習
海浪, ㄏㄞˇ ㄌㄤˋ, 水部, 乘風破浪"></textarea>
        </div>

        <button onclick="handleBatchImportText()" class="btn btn-pink" style="width: 100%; padding: 0.7rem; font-size: 0.9rem; justify-content: center;">🚀 一鍵匯入所有字詞</button>
      </div>
    </section>
  </main>

  <script>
    const apiKey = ""; // 執行環境自動帶入 Gemini API Key

    const DEFAULT_LESSONS = [
      { id: 1, title: "第1課 智救墨馬" },
      { id: 2, title: "第2課 掉進井裏的狐狸" },
      { id: 3, title: "第3課 迎風奔跑" },
      { id: 4, title: "第4課 點石成金" },
      { id: 5, title: "第5課 做人要誠實" },
      { id: 6, title: "第6課 做自己的主人" },
      { id: 7, title: "第7課 地理大發現" },
      { id: 8, title: "第8課 探索海洋" },
      { id: 9, title: "第9課 台灣的氣候" },
      { id: 10, title: "第10課 觀察與實踐" },
      { id: 11, title: "第11課 擁抱夢想" },
      { id: 12, title: "第12課 永不放棄" }
    ];

    const DEFAULT_DATA = [
      {
        id: "char_1_1",
        lessonId: 1,
        char: "墨",
        zhuyin: "ㄇㄛˋ",
        radical: "土部",
        strokes: "15畫",
        charMeaning: "黑色、書寫繪畫用的墨汁，亦指深黑色的馬匹。",
        terms: [
          { term: "墨汁", zhuyin: "ㄇㄛˋ ㄓ", def: "寫字或國畫所用的黑色液體。", sentence: "寫書法時，要小心不要把墨汁沾到衣服上。" },
          { term: "墨馬", zhuyin: "ㄇㄛˋ ㄇㄚˇ", def: "全身毛色純黑如墨的駿馬。", sentence: "國王十分愛惜那匹全身烏黑的墨馬。" }
        ]
      },
      {
        id: "char_2_1",
        lessonId: 2,
        char: "狐",
        zhuyin: "ㄏㄨˊ",
        radical: "犬部",
        strokes: "8畫",
        charMeaning: "狐狸，哺乳動物，機警敏捷。",
        terms: [
          { term: "狐狸", zhuyin: "ㄏㄨˊ ㄌㄧ˙", def: "耳尖尾長的野生動物，常被形容為狡猾。", sentence: "童話故事裡的狐狸總是充滿機智。" },
          { term: "狐假虎威", zhuyin: "ㄏㄨˊ ㄐㄧㄚˇ ㄏㄨˇ ㄨㄟ", def: "藉著有權勢者的威勢來欺壓他人。", sentence: "我們不該狐假虎威去仗勢欺人。" }
        ]
      }
    ];

    let appData = [];
    let currentTab = 'dict';
    let allRevealed = false;

    window.onload = function() {
      loadData();
      populateLessonDropdowns();
      renderApp();
    };

    function loadData() {
      const stored = localStorage.getItem('kanghan_5a_universal_dict_data');
      if (stored) {
        try { appData = JSON.parse(stored); } catch(e) { appData = DEFAULT_DATA; }
      } else {
        appData = DEFAULT_DATA;
        saveData();
      }
    }

    function saveData() { localStorage.setItem('kanghan_5a_universal_dict_data', JSON.stringify(appData)); }

    function resetToDefaultData() {
      if (confirm("確定要將所有資料恢復為預設國語課文嗎？")) {
        appData = DEFAULT_DATA;
        saveData();
        renderApp();
      }
    }

    function populateLessonDropdowns() {
      const select = document.getElementById('lessonSelect');
      const editSelect = document.getElementById('editLesson');
      const batchSelect = document.getElementById('batchLessonSelect');
      
      select.innerHTML = '<option value="all">📚 全部國語課次 (1-12課)</option>';
      editSelect.innerHTML = '';
      batchSelect.innerHTML = '';

      DEFAULT_LESSONS.forEach(l => {
        select.innerHTML += `<option value="${l.id}">${l.title}</option>`;
        editSelect.innerHTML += `<option value="${l.id}">${l.title}</option>`;
        batchSelect.innerHTML += `<option value="${l.id}">${l.title}</option>`;
      });
    }

    function switchTab(tab) {
      currentTab = tab;
      ['dict', 'quiz', 'manage', 'batch'].forEach(t => {
        document.getElementById(`view-${t}`).classList.toggle('hidden', t !== tab);
        document.getElementById(`tab-${t}`).classList.toggle('active', t === tab);
      });
      renderApp();
    }

    /* 🌐 線上萬能 AI 字典即時查詢 */
    async function performUniversalSearch() {
      const query = document.getElementById('searchInput').value.trim();
      if (!query) return alert("請輸入想要查詢的字或詞語！");

      const resultArea = document.getElementById('onlineSearchResultArea');
      resultArea.classList.remove('hidden');
      resultArea.innerHTML = `
        <div class="online-result-card" style="text-align:center; padding: 2rem;">
          <div class="loading-spinner"></div>
          <p style="margin-top: 0.75rem; font-weight:700; color:#831843;">正在為您線上調閱教育部與字典資料庫《${query}》...</p>
        </div>
      `;

      try {
        const promptText = `你是一個專業的小學國語線上字典助手。請詳細解析詞語或單字「${query}」。
請以 JSON 格式回應，包含以下欄位：
{
  "char": "${query}",
  "zhuyin": "注音符號",
  "radical": "部首（若是單字）或詞性（若是詞語）",
  "strokes": "總筆劃數（若無可填無）",
  "charMeaning": "簡明易懂的國語字義或詞義解釋",
  "terms": [
    { "term": "相關圈詞1", "zhuyin": "注音", "def": "解釋", "sentence": "適合小學生的標準造句" },
    { "term": "相關圈詞2", "zhuyin": "注音", "def": "解釋", "sentence": "適合小學生的標準造句" }
  ]
}`;

        let response = null;
        let retries = [1000, 2000, 4000];

        for (let delay of retries) {
          try {
            const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                contents: [{ parts: [{ text: promptText }] }],
                generationConfig: { responseMimeType: "application/json" }
              })
            });
            if (res.ok) {
              response = await res.json();
              break;
            }
          } catch(e) {}
          await new Promise(r => setTimeout(r, delay));
        }

        if (response && response.candidates && response.candidates[0]) {
          const dictData = JSON.parse(response.candidates[0].content.parts[0].text);
          renderOnlineResult(dictData);
        } else {
          fallbackMoeSearch(query);
        }
      } catch(e) {
        fallbackMoeSearch(query);
      }
    }

    function renderOnlineResult(data) {
      const resultArea = document.getElementById('onlineSearchResultArea');
      resultArea.innerHTML = `
        <div class="online-result-card">
          <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.75rem;">
            <span class="badge" style="font-size:0.8rem; padding:0.2rem 0.6rem;">🌐 線上國語字典解析結果</span>
            <button onclick="saveOnlineWordToDict(${JSON.stringify(data).replace(/"/g, '&quot;')})" class="btn btn-pink">
              ➕ 一鍵將《${data.char}》存入我的字典
            </button>
          </div>

          <div class="online-char-header">
            <div class="online-char-box">${data.char.substring(0, 2)}</div>
            <div>
              <div style="font-size:1.4rem; font-weight:900; color:#831843;">
                ${data.char} <span style="color:#db2777; font-size:1rem;">［${data.zhuyin}］</span>
                <button onclick="speakText('${data.char}')" class="audio-btn" style="display:inline-flex; width:2rem; height:2rem; font-size:0.9rem; margin-left:0.5rem;">🔊</button>
              </div>
              <div style="margin-top:0.3rem;">
                ${data.radical ? `<span class="meta-tag">部首/詞性：${data.radical}</span>` : ''}
                ${data.strokes ? `<span class="meta-tag">筆劃：${data.strokes}</span>` : ''}
              </div>
            </div>
          </div>

          <div style="font-size:0.85rem; color:#831843; margin-bottom:1rem; line-height:1.5;">
            <strong>【詳細釋義】：</strong>${data.charMeaning}
          </div>

          <h4 style="font-size:0.9rem; color:#831843; font-weight:800; margin-bottom:0.5rem;">🌸 相關延伸圈詞與例句：</h4>
          ${data.terms ? data.terms.map(t => `
            <div class="term-item">
              <div class="term-title">
                <span>${t.term} <small style="color:#db2777;">(${t.zhuyin})</small></span>
                <button onclick="speakText('${t.term}')" style="border:none; background:none; cursor:pointer;">🔊</button>
              </div>
              ${t.def ? `<div class="term-def">解釋：${t.def}</div>` : ''}
              ${t.sentence ? `<div class="sentence-box">💬 造句：${t.sentence}</div>` : ''}
            </div>
          `).join('') : ''}

          <div style="margin-top:1rem; text-align:right;">
            <button onclick="openMoeDict('${data.char}')" class="btn btn-soft" style="font-size:0.75rem;">🏛️ 前往教育部國語辭典深入閱讀</button>
          </div>
        </div>
      `;
    }

    function fallbackMoeSearch(query) {
      const resultArea = document.getElementById('onlineSearchResultArea');
      resultArea.innerHTML = `
        <div class="online-result-card" style="text-align:center; padding:1.5rem;">
          <h3 style="color:#831843; margin-bottom:0.5rem;">🏛️ 正在為您連線教育部國語辭典...</h3>
          <p style="font-size:0.8rem; color:#9d174d; margin-bottom:1rem;">點擊下方按鈕將直接開啟教育部線上字典頁面查詢《${query}》：</p>
          <button onclick="openMoeDict('${query}')" class="btn btn-pink" style="padding:0.6rem 1.5rem;">
            🏛️ 開啟教育部辭典搜尋《${query}》
          </button>
        </div>
      `;
    }

    function saveOnlineWordToDict(wordObj) {
      wordObj.id = 'char_' + Date.now();
      wordObj.lessonId = 1; // 預設存入第一課
      appData.unshift(wordObj);
      saveData();
      renderApp();
      alert(`🎉 成功將《${wordObj.char}》存入您的個人隨身字典庫囉！`);
    }

    function renderApp() {
      const lessonVal = document.getElementById('lessonSelect').value;
      const searchVal = document.getElementById('searchInput').value.trim().toLowerCase();

      const filtered = appData.filter(item => {
        const matchLesson = (lessonVal === 'all') || (item.lessonId.toString() === lessonVal);
        const matchChar = item.char.includes(searchVal) || 
                          item.zhuyin.includes(searchVal) || 
                          (item.terms && item.terms.some(t => t.term.includes(searchVal)));
        return matchLesson && (!searchVal || matchChar);
      });

      if (currentTab === 'dict') renderDict(filtered);
      else if (currentTab === 'quiz') renderQuiz(filtered);
    }

    function openMoeDict(word) {
      const url = `https://dict.revised.moe.edu.tw/search.jsp?md=1&word=${encodeURIComponent(word)}`;
      window.open(url, '_blank');
    }

    function renderDict(items) {
      const container = document.getElementById('dictContentList');
      if (items.length === 0) {
        container.innerHTML = '<div style="grid-column: 1/-1; text-align:center; padding:3rem; color:#9d174d;">🌸 字典庫中暫無符合條件的字詞，請點上方『🔎 線上查詢』隨時查字典！</div>';
        return;
      }

      container.innerHTML = items.map(item => `
        <div class="char-card">
          <div class="card-body">
            <div class="card-top">
              <span class="lesson-badge">第 ${item.lessonId} 課</span>
              <button onclick="speakText('${item.char}')" class="audio-btn" title="聽國語發音">🔊</button>
            </div>

            <div class="char-header" style="display:flex; align-items:center; gap:0.85rem; margin-bottom:0.75rem; padding-bottom:0.75rem; border-bottom:2px dashed #fce7f3;">
              <div class="char-box" style="width:4.2rem; height:4.2rem; background-color:#fff1f2; border:2.5px solid #fda4af; border-radius:1.25rem; display:flex; align-items:center; justify-content:center; font-size:2.2rem; font-weight:900; color:#9f1239;">${item.char.substring(0, 2)}</div>
              <div>
                <div style="font-size:1.2rem; font-weight:800; color:#831843;">
                  ${item.char} <span style="color:#db2777; font-size:0.9rem;">［${item.zhuyin}］</span>
                </div>
                <div style="margin-top:0.2rem;">
                  <span class="meta-tag">部首：${item.radical}</span>
                  ${item.strokes ? `<span class="meta-tag">${item.strokes}</span>` : ''}
                </div>
              </div>
            </div>

            ${item.charMeaning ? `<div style="font-size:0.78rem; color:#831843; margin-bottom:0.5rem; line-height:1.4;"><strong>釋義：</strong>${item.charMeaning}</div>` : ''}

            ${item.terms ? item.terms.map(t => `
              <div class="term-item">
                <div class="term-title">
                  <span>${t.term} <small style="color:#db2777;">(${t.zhuyin})</small></span>
                  <button onclick="speakText('${t.term}')" style="border:none; background:none; cursor:pointer;">🔊</button>
                </div>
                ${t.def ? `<div class="term-def">解釋：${t.def}</div>` : ''}
                ${t.sentence ? `<div class="sentence-box">💬 造句：${t.sentence}</div>` : ''}
              </div>
            `).join('') : ''}
          </div>

          <div class="card-footer">
            <div>
              <button onclick="openMoeDict('${item.char}')" style="color:#0284c7; border:none; background:none; font-weight:800; cursor:pointer;">🏛️ 教育部辭典</button>
            </div>
            <div>
              <button onclick="editCharItem('${item.id}')" style="color:#9d174d; border:none; background:none; font-weight:700; cursor:pointer;">✏️ 編輯</button>
              <button onclick="deleteCharItem('${item.id}')" style="color:#fb7185; border:none; background:none; font-weight:700; cursor:pointer; margin-left:0.3rem;">🗑️ 刪除</button>
            </div>
          </div>
        </div>
      `).join('');
    }

    function renderQuiz(items) {
      const container = document.getElementById('quizListContainer');
      let allTerms = [];
      items.forEach(item => {
        if (item.terms) {
          item.terms.forEach(t => {
            allTerms.push({ ...t, lessonId: item.lessonId, char: item.char });
          });
        }
      });

      if (allTerms.length === 0) {
        container.innerHTML = '<div style="text-align:center; padding:2rem; color:#9d174d;">🌸 暫無圈詞測驗項目！</div>';
        return;
      }

      container.innerHTML = allTerms.map((t, idx) => `
        <div class="quiz-card">
          <div style="flex:1;">
            <div style="font-size:0.75rem; color:#9d174d; margin-bottom:0.2rem;">
              第 ${t.lessonId} 課 測驗 ${idx + 1}
            </div>
            <div style="font-size:1.05rem; font-weight:800;">
              <span class="quiz-mask ${allRevealed ? 'revealed' : ''}" onclick="this.classList.toggle('revealed')">
                ${t.term}
              </span>
              <span style="font-size:0.85rem; color:#db2777; font-weight:600; margin-left:0.3rem;">(${t.zhuyin})</span>
            </div>
            ${t.def ? `<div style="font-size:0.75rem; color:#64748b; margin-top:0.2rem;">提示：${t.def}</div>` : ''}
          </div>
          <button onclick="speakText('${t.term}')" class="btn btn-pink" style="padding:0.5rem 0.9rem;">
            🔊 播放題目
          </button>
        </div>
      `).join('');
    }

    function toggleAllQuizMasks() {
      allRevealed = !allRevealed;
      document.querySelectorAll('.quiz-mask').forEach(m => {
        if (allRevealed) m.classList.add('revealed');
        else m.classList.remove('revealed');
      });
    }

    function speakText(text) {
      if (!('speechSynthesis' in window)) return alert("您的瀏覽器不支援語音功能");
      window.speechSynthesis.cancel();
      const u = new SpeechSynthesisUtterance(text);
      u.lang = 'zh-TW';
      const rateVal = parseFloat(document.getElementById('speechRateSelect').value) || 0.8;
      u.rate = rateVal;
      window.speechSynthesis.speak(u);
    }

    function handleBatchImportText() {
      const lessonId = parseInt(document.getElementById('batchLessonSelect').value, 10);
      const rawText = document.getElementById('batchInputText').value.trim();
      if (!rawText) return alert("請先貼上文字資料！");

      const lines = rawText.split('\n');
      let count = 0;

      lines.forEach(line => {
        const parts = line.split(',').map(p => p.trim());
        if (parts.length >= 1 && parts[0] !== '') {
          const char = parts[0];
          const zhuyin = parts[1] || '';
          const radical = parts[2] || '通用部';
          const term = parts[3] || char;

          appData.push({
            id: 'char_' + Date.now() + '_' + Math.random().toString(36).substr(2, 4),
            lessonId, char, zhuyin, radical, strokes: '', charMeaning: '',
            terms: [{ term, zhuyin: '', def: '', sentence: '' }]
          });
          count++;
        }
      });

      saveData();
      document.getElementById('batchInputText').value = '';
      alert(`🎉 成功批次匯入 ${count} 筆字詞！`);
      switchTab('dict');
    }

    function exportData() {
      const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(appData, null, 2));
      const downloadAnchor = document.createElement('a');
      downloadAnchor.setAttribute("href", dataStr);
      downloadAnchor.setAttribute("download", "國語線上字典備份.json");
      document.body.appendChild(downloadAnchor);
      downloadAnchor.click();
      downloadAnchor.remove();
    }

    function triggerImport() { document.getElementById('importFile').click(); }

    function handleFileImport(e) {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = function(event) {
        try {
          const imported = JSON.parse(event.target.result);
          if (Array.isArray(imported)) {
            appData = imported;
            saveData();
            renderApp();
            alert("🎉 JSON 備份檔匯入成功！");
          }
        } catch(err) { alert("匯入失敗，請確認檔案格式正確。"); }
      };
      reader.readAsText(file);
    }

    function handleSaveForm(e) {
      e.preventDefault();
      const editId = document.getElementById('editCharId').value;
      const lessonId = parseInt(document.getElementById('editLesson').value, 10);
      const char = document.getElementById('editChar').value.trim();
      const zhuyin = document.getElementById('editZhuyin').value.trim();
      const radical = document.getElementById('editRadical').value.trim();
      const strokes = document.getElementById('editStrokes').value.trim();
      const charMeaning = document.getElementById('editCharMeaning').value.trim();

      const term1 = document.getElementById('editTerm1').value.trim();
      const term1Zhuyin = document.getElementById('editTerm1Zhuyin').value.trim();
      const term1Def = document.getElementById('editTerm1Def').value.trim();
      const term1Sentence = document.getElementById('editTerm1Sentence').value.trim();

      const terms = [{ term: term1, zhuyin: term1Zhuyin, def: term1Def, sentence: term1Sentence }];

      const itemData = {
        id: editId || ('char_' + Date.now()),
        lessonId, char, zhuyin, radical, strokes, charMeaning, terms
      };

      if (editId) {
        const idx = appData.findIndex(i => i.id === editId);
        if (idx !== -1) appData[idx] = itemData;
      } else {
        appData.push(itemData);
      }

      saveData();
      document.getElementById('editForm').reset();
      switchTab('dict');
    }

    function editCharItem(id) {
      const item = appData.find(i => i.id === id);
      if (!item) return;
      switchTab('manage');
      document.getElementById('editCharId').value = item.id;
      document.getElementById('editLesson').value = item.lessonId;
      document.getElementById('editChar').value = item.char;
      document.getElementById('editZhuyin').value = item.zhuyin;
      document.getElementById('editRadical').value = item.radical;
      document.getElementById('editStrokes').value = item.strokes || '';
      document.getElementById('editCharMeaning').value = item.charMeaning || '';

      if (item.terms && item.terms[0]) {
        document.getElementById('editTerm1').value = item.terms[0].term || '';
        document.getElementById('editTerm1Zhuyin').value = item.terms[0].zhuyin || '';
        document.getElementById('editTerm1Def').value = item.terms[0].def || '';
        document.getElementById('editTerm1Sentence').value = item.terms[0].sentence || '';
      }
    }

    function deleteCharItem(id) {
      if (confirm("確定要刪除這個字詞嗎？")) {
        appData = appData.filter(i => i.id !== id);
        saveData();
        renderApp();
      }
    }
  </script>
</body>
</html>

